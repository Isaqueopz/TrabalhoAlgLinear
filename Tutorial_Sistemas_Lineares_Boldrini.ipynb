    "# Análise de posto, nulidade e número de soluções\n",
    "# Sistema: x + y + z = 1, x + y + 2*z = 2, 2*x + 2*y + 3*z = 3\n",
    "A = sp.Matrix([[1, 1, 1], [1, 1, 2], [2, 2, 3]])  # Matriz dos coeficientes\n",
