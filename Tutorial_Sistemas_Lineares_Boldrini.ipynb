   "source": [
    "# Exemplo: Cálculo e visualização de autovetores\n",
    "import sympy as sp\n",
    "sp.init_printing(use_latex='mathjax')\n",
    "\n",
    "# Matriz quadrada de ordem 2\n",
    "A = sp.Matrix([[2, 0], [0, 3]])\n",
    "\n",
    "# Cálculo dos autovalores e autovetores\n",
    "autovalores = A.eigenvals()\n",
    "autovetores = A.eigenvects()\n",
    "\n",
    "print(\"Matriz A:\")\n",
    "display(A)\n",
    "print(\"Autovalores de A:\")\n",
    "display(autovalores)\n",
    "print(\"Autovetores de A:\")\n",
    "for val, mult, vects in autovetores:\n",
    "    print(f\"λ = {val}\")\n",
    "    for v in vects:\n",
    "        display(v)"
   ]
