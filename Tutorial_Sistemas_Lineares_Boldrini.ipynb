       "⎣-16⎦"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# Implementação da Regra de Cramer\n",
    "A = sp.Matrix([[2, -1, 3], [1, 0, 1], [1, 2, 0]])\n",
    "B = sp.Matrix([[5], [6], [4]])\n",
    "\n",
    "n = A.shape[0]\n",
    "sol_cramer = []\n",
    "det_A = A.det()\n",
    "print(f\"Determinante de A: {det_A}\")\n",
    "\n",
    "if det_A != 0:\n",
    "    for i in range(n):\n",
    "        Ai = A.copy()\n",
    "        Ai[:, i] = B\n",
    "        xi = Ai.det() / det_A\n",
    "        sol_cramer.append(xi)\n",
    "    print(\"Solução pelo método de Cramer:\")\n",
    "    display(sp.Matrix(sol_cramer))\n",
    "else:\n",
    "    print(\"O sistema não admite solução única (determinante zero).\")"
   ]
