    "## 11. Aplicação Prática: Balanceamento de Reações Químicas\n",
    "\n",
    "### Exemplo do Boldrini (p. 29)\n",
    "\n",
    "Balancear: $xH_2 + yO_2 \\rightarrow zH_2O$\n",
    "\n",
    "Montando o sistema:\n",
    "- Hidrogênio: $2x = 2z$\n",
    "- Oxigênio: $2y = z$\n",
    "\n",
    "### Modelagem e solução simbólica com SymPy"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 84,
   "id": "103450b0",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Coeficientes: [2, 1, 2]\n"
     ]
    }
   ],
   "source": [
    "import sympy as sp\n",
    "import re\n",
    "\n",
    "def balancear_reacao(reagentes, produtos):\n",
    "    elementos = set(re.findall(r'[A-Z][a-z]?', reagentes + produtos))\n",
    "    \n",
    "    comp_reag = reagentes.split(' + ')\n",
    "    comp_prod = produtos.split(' + ')\n",
    "    comps = comp_reag + comp_prod\n",
    "    variaveis = sp.symbols(f'v0:{len(comps)}')\n",
    "    \n",
    "    def extrair_atomos(composto):\n",
    "        return {el: sum(int(n or 1) for n in re.findall(rf'{el}(\\d*)', composto)) for el in elementos}\n",
    "\n",
    "    sistema = []\n",
    "    for el in elementos:\n",
    "        eq = 0\n",
    "        for i, comp in enumerate(comp_reag):\n",
    "            eq += extrair_atomos(comp).get(el, 0) * variaveis[i]\n",
    "        for i, comp in enumerate(comp_prod):\n",
    "            eq -= extrair_atomos(comp).get(el, 0) * variaveis[len(comp_reag) + i]\n",
    "        sistema.append(eq)\n",
    "\n",
    "    solucoes = sp.solve(sistema, variaveis, dict=True)\n",
    "    if not solucoes: return \"Não foi possível balancear.\"\n",
    "    \n",
    "    s = solucoes[0]\n",
    "    \n",
    "    # Substitui variáveis livres por 1 para obter valores numéricos\n",
    "    subs = {v: 1 for v in variaveis if v not in s}\n",
    "    # Adiciona as variáveis que foram resolvidas, mas que podem conter símbolos livres\n",
    "    for v in s:\n",
    "        s[v] = s[v].subs(subs)\n",
    "    # Garante que as variáveis livres também estejam no dicionário final\n",
    "    for v, val in subs.items():\n",
    "        s[v] = sp.Integer(val)\n",
    "\n",
    "    # Agora todos os valores em 's' são números do SymPy (racionais)\n",
    "    denominadores = [sp.denom(s[v]) for v in variaveis]\n",
    "    mmc = sp.lcm(denominadores)\n",
    "    \n",
    "    res = [int(s[v] * mmc) for v in variaveis]\n",
    "    return res\n",
    "\n",
